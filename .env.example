# Variables para la función serverless api/contact.ts
# Configúralas en el dashboard de Vercel (Settings > Environment Variables)
# Para desarrollo local, cópialas a .env.local (no commitear)

EMAILJS_PRIVATE_KEY=your_private_key_here
EMAILJS_PUBLIC_KEY=your_public_key_here
EMAILJS_SERVICE_ID=your_service_id_here
EMAILJS_TEMPLATE_ID=your_template_id_here

# EmailJS Dashboard → Account → Security:
# - Activar "Use Private Key"
# - Activar "Allow API for non-browser applications"
